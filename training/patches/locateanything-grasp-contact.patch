@@ -0,0 +1,290 @@
+"""Loss utilities for joint two-contact-point PBD training."""
+
+from __future__ import annotations
+
+import math
+from dataclasses import dataclass
+
+import torch
+import torch.nn.functional as F
+
+
+@dataclass
+class ContactLossOutput:
+    pair_sum: torch.Tensor
+    center_sum: torch.Tensor
+    angle_sum: torch.Tensor
+    width_sum: torch.Tensor
+    contact_count: torch.Tensor
+    geometry_active_count: torch.Tensor
+    coord_mass_min: torch.Tensor
+    coord_entropy_max: torch.Tensor
+
+
+def validate_coordinate_token_range(start_token_id: int, end_token_id: int) -> None:
+    if end_token_id - start_token_id != 1000:
+        raise ValueError(
+            "contact loss requires exactly 1001 contiguous coordinate tokens; "
+            f"got IDs [{start_token_id}, {end_token_id}]"
+        )
+
+
+def pi_periodic_angle_loss(cosine: torch.Tensor) -> torch.Tensor:
+    """Return the smooth, endpoint-exchange-invariant angular loss."""
+    return 1.0 - cosine.clamp(-1.0, 1.0).square()
+
+
+def _empty_output(hidden_states: torch.Tensor) -> ContactLossOutput:
+    zero = hidden_states.sum() * 0.0
+    scalar_zero = zero.detach().new_zeros(())
+    return ContactLossOutput(
+        pair_sum=zero,
+        center_sum=zero,
+        angle_sum=zero,
+        width_sum=zero,
+        contact_count=scalar_zero,
+        geometry_active_count=scalar_zero,
+        coord_mass_min=scalar_zero,
+        coord_entropy_max=scalar_zero,
+    )
+
+
+def _filter_colliding_candidates(
+    candidate_mask: torch.Tensor,
+    candidate_collision_2d: torch.Tensor | None,
+    candidate_outside_2d: torch.Tensor | None,
+    collision_valid: torch.Tensor | None,
+    collision_threshold: float,
+    outside_threshold: float,
+) -> torch.Tensor:
+    if candidate_collision_2d is None and candidate_outside_2d is None:
+        return candidate_mask
+
+    safe_candidates = candidate_mask.clone()
+    filterable = torch.zeros(
+        (candidate_mask.shape[0], 1),
+        dtype=torch.bool,
+        device=candidate_mask.device,
+    )
+    if candidate_outside_2d is not None:
+        outside_finite = torch.isfinite(candidate_outside_2d)
+        outside_known = (outside_finite | ~candidate_mask).all(
+            dim=-1, keepdim=True
+        )
+        outside_safe = outside_finite & (
+            candidate_outside_2d <= outside_threshold
+        )
+        safe_candidates &= torch.where(
+            outside_known, outside_safe, candidate_mask
+        )
+        filterable |= outside_known
+
+    if candidate_collision_2d is not None and collision_valid is not None:
+        collision_known = collision_valid.bool().unsqueeze(-1)
+        collision_safe = torch.isfinite(candidate_collision_2d) & (
+            candidate_collision_2d <= collision_threshold
+        )
+        safe_candidates &= torch.where(
+            collision_known, collision_safe, candidate_mask
+        )
+        filterable |= collision_known
+
+    has_safe_candidate = safe_candidates.any(dim=-1, keepdim=True)
+    may_filter = filterable & has_safe_candidate
+    return torch.where(may_filter, safe_candidates, candidate_mask)
+
+
+def compute_contact_auxiliary_losses(
+    *,
+    hidden_states: torch.Tensor,
+    lm_head_weight: torch.Tensor,
+    contact_mtp_coord_mask: torch.Tensor,
+    contact_candidates: torch.Tensor,
+    contact_candidate_mask: torch.Tensor,
+    contact_positive_mask: torch.Tensor,
+    contact_image_size: torch.Tensor,
+    coord_start_token_id: int,
+    coord_end_token_id: int,
+    candidate_collision_2d: torch.Tensor | None = None,
+    candidate_outside_2d: torch.Tensor | None = None,
+    collision_valid: torch.Tensor | None = None,
+    collision_threshold: float = 0.0,
+    outside_threshold: float = 0.0,
+    coord_mass_threshold: float = 0.35,
+    coord_entropy_threshold: float = 0.85,
+    minimum_width_diagonal: float = 1e-4,
+) -> ContactLossOutput:
+    """Compute hard-min pair CE and gated image-space geometry losses.
+
+    ``contact_mtp_coord_mask`` is label-aligned. The causal shift is applied here,
+    so each selected hidden state predicts one of the four coordinate labels.
+    """
+
+    validate_coordinate_token_range(coord_start_token_id, coord_end_token_id)
+    if contact_mtp_coord_mask.shape != hidden_states.shape[:2]:
+        raise ValueError(
+            "contact coordinate mask must match hidden sequence shape: "
+            f"mask={tuple(contact_mtp_coord_mask.shape)}, "
+            f"hidden={tuple(hidden_states.shape[:2])}"
+        )
+
+    shift_mask = contact_mtp_coord_mask[..., 1:].bool().reshape(-1)
+    selected_hidden = hidden_states[..., :-1, :].reshape(
+        -1, hidden_states.shape[-1]
+    )[shift_mask]
+    if selected_hidden.numel() == 0:
+        if contact_positive_mask.bool().any():
+            raise ValueError("positive contact sample has no four-coordinate MTP block")
+        return _empty_output(hidden_states)
+    if selected_hidden.shape[0] % 4 != 0:
+        raise ValueError(
+            "contact MTP coordinate mask must select a multiple of four slots; "
+            f"got {selected_hidden.shape[0]}"
+        )
+
+    block_count = selected_hidden.shape[0] // 4
+    positive_indices = contact_positive_mask.bool().nonzero(as_tuple=False).flatten()
+    if positive_indices.numel() != block_count:
+        raise ValueError(
+            "positive sample/contact block count mismatch: "
+            f"positive_samples={positive_indices.numel()}, blocks={block_count}"
+        )
+
+    candidates = contact_candidates[positive_indices].long()
+    candidate_mask = contact_candidate_mask[positive_indices].bool()
+    image_size = contact_image_size[positive_indices].float()
+    if candidates.ndim != 3 or candidates.shape[-1] != 4:
+        raise ValueError(
+            "contact_candidates must have shape [samples, K, 4], "
+            f"got {candidates.shape}"
+        )
+    if not candidate_mask.any(dim=-1).all():
+        raise ValueError("every positive contact sample needs at least one candidate")
+    if (candidates[candidate_mask] < 0).any() or (
+        candidates[candidate_mask] > 1000
+    ).any():
+        raise ValueError("contact candidate values must be in [0, 1000]")
