+"""Loss utilities for direct rectangular-grasp PBD training."""
+
+from __future__ import annotations
+
+import math
+from dataclasses import dataclass
+
+import torch
+import torch.nn.functional as F
+from eaglevl.train.grasp_contact import validate_coordinate_token_range
+
+
+@dataclass
+class GraspRectLossOutput:
+    pose_sum: torch.Tensor
+    center_sum: torch.Tensor
+    angle_sum: torch.Tensor
+    width_sum: torch.Tensor
+    grasp_count: torch.Tensor
+    geometry_active_count: torch.Tensor
+    coord_mass_min: torch.Tensor
+    coord_entropy_max: torch.Tensor
+    angle_resultant_min: torch.Tensor
+    cx_top1_correct: torch.Tensor
+    cy_top1_correct: torch.Tensor
+    theta_exact_top1_correct: torch.Tensor
+    theta_circular_within1_correct: torch.Tensor
+    width_top1_correct: torch.Tensor
+    pose_four_slot_top1_correct: torch.Tensor
+
+
+def circular_angle_neighbors(
+    target_bins: torch.Tensor,
+    radius: int,
+    bin_count: int = 1001,
+) -> torch.Tensor:
+    radius = int(radius)
+    if radius < 0:
+        raise ValueError("angle wrap radius must be non-negative")
+    if bin_count <= 0:
+        raise ValueError("angle bin count must be positive")
+    offsets = torch.arange(
+        -radius,
+        radius + 1,
+        device=target_bins.device,
+        dtype=target_bins.dtype,
+    )
+    return torch.remainder(target_bins.unsqueeze(-1) + offsets, bin_count)
+
+
+def wrapped_angle_marginal_nll(
+    full_log_probs: torch.Tensor,
+    target_bins: torch.Tensor,
+    *,
+    coord_start_token_id: int,
+    radius: int = 1,
+    bin_count: int = 1001,
+) -> torch.Tensor:
+    """Marginalize one circular quantization neighborhood in full vocabulary."""
+    if full_log_probs.shape[:-1] != target_bins.shape:
+        raise ValueError(
+            "angle log-prob and target shapes must align: "
+            f"log_probs={tuple(full_log_probs.shape)}, "
+            f"targets={tuple(target_bins.shape)}"
+        )
+    if (target_bins < 0).any() or (target_bins >= bin_count).any():
+        raise ValueError("angle target bins are outside the circular vocabulary")
+    neighbors = circular_angle_neighbors(target_bins.long(), radius, bin_count)
+    token_ids = neighbors + int(coord_start_token_id)
+    if token_ids.max() >= full_log_probs.shape[-1]:
+        raise ValueError("angle coordinate token IDs exceed full vocabulary")
+    neighbor_log_probs = full_log_probs.gather(-1, token_ids)
+    return -torch.logsumexp(neighbor_log_probs, dim=-1)
+
+
+def double_angle_distribution(
+    conditional_angle_probs: torch.Tensor,
+) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
+    if conditional_angle_probs.shape[-1] != 1001:
+        raise ValueError("double-angle distribution requires 1001 angle bins")
+    bins = torch.arange(
+        1001,
+        device=conditional_angle_probs.device,
+        dtype=torch.float32,
+    )
+    phase = 2.0 * math.pi * bins / 1001.0
+    cosine = (conditional_angle_probs.float() * phase.cos()).sum(dim=-1)
+    sine = (conditional_angle_probs.float() * phase.sin()).sum(dim=-1)
+    resultant = torch.sqrt(cosine.square() + sine.square())
+    return cosine, sine, resultant
+
+
+def double_angle_loss(
+    conditional_angle_probs: torch.Tensor,
+    target_bins: torch.Tensor,
+) -> tuple[torch.Tensor, torch.Tensor]:
+    cosine, sine, resultant = double_angle_distribution(
+        conditional_angle_probs
+    )
+    target_phase = 2.0 * math.pi * target_bins.float() / 1001.0
+    alignment = (
+        cosine * target_phase.cos() + sine * target_phase.sin()
+    ) / resultant.clamp_min(1e-8)
+    return 1.0 - alignment.clamp(-1.0, 1.0), resultant
+
+
+def _empty_output(hidden_states: torch.Tensor) -> GraspRectLossOutput:
+    zero = hidden_states.sum() * 0.0
+    scalar_zero = zero.detach().new_zeros(())
+    return GraspRectLossOutput(
+        pose_sum=zero,
+        center_sum=zero,
+        angle_sum=zero,
+        width_sum=zero,
+        grasp_count=scalar_zero,
+        geometry_active_count=scalar_zero,
+        coord_mass_min=scalar_zero.new_ones(()),
+        coord_entropy_max=scalar_zero,
+        angle_resultant_min=scalar_zero.new_ones(()),
+        cx_top1_correct=scalar_zero,
+        cy_top1_correct=scalar_zero,
+        theta_exact_top1_correct=scalar_zero,
+        theta_circular_within1_correct=scalar_zero,
+        width_top1_correct=scalar_zero,
+        pose_four_slot_top1_correct=scalar_zero,
+    )
+
+
+def compute_grasp_rect_auxiliary_losses(
+    *,
+    hidden_states: torch.Tensor,
+    lm_head_weight: torch.Tensor,
+    grasp_rect_mtp_coord_mask: torch.Tensor,
+    grasp_rect_candidates: torch.Tensor,
+    grasp_rect_candidate_mask: torch.Tensor,
+    grasp_rect_positive_mask: torch.Tensor,
+    grasp_rect_image_size: torch.Tensor,
+    coord_start_token_id: int,
+    coord_end_token_id: int,
+    lm_head: torch.nn.Module | None = None,
+    angle_wrap_radius: int = 1,
+    coord_mass_threshold: float = 0.35,
+    coord_entropy_threshold: float = 0.85,
+    angle_resultant_threshold: float = 0.05,
+    minimum_width_diagonal: float = 1e-4,
+) -> GraspRectLossOutput:
+    validate_coordinate_token_range(coord_start_token_id, coord_end_token_id)
+    if grasp_rect_mtp_coord_mask.shape != hidden_states.shape[:2]:
+        raise ValueError("grasp rect coordinate mask must match hidden sequence")
+
+    shift_mask = grasp_rect_mtp_coord_mask[..., 1:].bool().reshape(-1)
+    selected_hidden = hidden_states[..., :-1, :].reshape(
+        -1, hidden_states.shape[-1]
+    )[shift_mask]
+    if selected_hidden.numel() == 0:
+        if grasp_rect_positive_mask.bool().any():
+            raise ValueError("positive grasp rect sample has no four-slot MTP block")
+        return _empty_output(hidden_states)
+    if selected_hidden.shape[0] % 4 != 0:
+        raise ValueError("grasp rect coordinate mask must select four-slot blocks")
+
+    block_count = selected_hidden.shape[0] // 4
+    positive_indices = (
+        grasp_rect_positive_mask.bool().nonzero(as_tuple=False).flatten()
+    )
+    if positive_indices.numel() != block_count:
+        raise ValueError("positive sample/grasp rect block count mismatch")
+    candidates = grasp_rect_candidates[positive_indices].long()
+    candidate_mask = grasp_rect_candidate_mask[positive_indices].bool()
+    image_size = grasp_rect_image_size[positive_indices].float()
+    if candidates.ndim != 3 or candidates.shape[-1] != 4:
+        raise ValueError("grasp_rect_candidates must have shape [samples, K, 4]")
+    if not candidate_mask.any(dim=-1).all():
+        raise ValueError("every positive grasp rect sample needs a candidate")
+    if (candidates[candidate_mask] < 0).any() or (
+        candidates[candidate_mask] > 1000
+    ).any():
+        raise ValueError("grasp rect candidate values must be in [0, 1000]")
+    if (
+        candidates[..., 3][candidate_mask].float() / 1000.0
+        <= float(minimum_width_diagonal)
+    ).any():
+        raise ValueError("grasp rect candidate width must exceed minimum")
+    if (image_size <= 0).any() or not torch.isfinite(image_size).all():
+        raise ValueError("positive grasp rect samples need positive image sizes")
+
+    block_hidden = selected_hidden.reshape(block_count, 4, -1)
+    if lm_head is None:
+        logits = torch.einsum(
+            "bph,vh->bpv",
+            block_hidden.to(dtype=lm_head_weight.dtype),
+            lm_head_weight,
+        )
+    else:
+        logits = lm_head(block_hidden.to(dtype=lm_head_weight.dtype))
+    log_probs = F.log_softmax(logits.float(), dim=-1)
+
+    expanded_log_probs = log_probs.unsqueeze(1).expand(
+        -1, candidates.shape[1], -1, -1
+    )
+    coordinate_target_ids = candidates + coord_start_token_id
+    standard_log_probs = expanded_log_probs.gather(
+        -1, coordinate_target_ids.unsqueeze(-1)
+    ).squeeze(-1)
+    angle_log_probs = wrapped_angle_marginal_nll(
+        expanded_log_probs[:, :, 2, :],
+        candidates[:, :, 2],
+        coord_start_token_id=coord_start_token_id,
+        radius=angle_wrap_radius,
+    )
+    slot_losses = -standard_log_probs
+    slot_losses[..., 2] = angle_log_probs
+    candidate_losses = slot_losses.mean(dim=-1).masked_fill(
+        ~candidate_mask, torch.inf
+    )
+    pose_per_block, best_candidate_index = candidate_losses.min(dim=-1)
+    if not torch.isfinite(pose_per_block).all():
+        raise FloatingPointError("non-finite grasp rect pose loss")
+    batch_indices = torch.arange(block_count, device=hidden_states.device)
+    best_target = candidates[batch_indices, best_candidate_index].float()
+
+    coord_probs = log_probs[
+        ..., coord_start_token_id : coord_end_token_id + 1
+    ].exp()
+    coord_mass = coord_probs.sum(dim=-1)
+    conditional_probs = coord_probs / coord_mass.unsqueeze(-1).clamp_min(1e-12)
+    predicted_bins = conditional_probs.argmax(dim=-1)
+    target_bins = best_target.long()
+    exact_slots = predicted_bins.eq(target_bins)
+    theta_neighbors = circular_angle_neighbors(target_bins[:, 2], radius=1)
+    theta_within1 = predicted_bins[:, 2].unsqueeze(-1).eq(
+        theta_neighbors
+    ).any(dim=-1)
+    coordinate_values = torch.arange(
+        1001, device=hidden_states.device, dtype=torch.float32
+    )
+    linear_soft_values = (
+        conditional_probs * coordinate_values.view(1, 1, -1)
+    ).sum(dim=-1)
+    coord_entropy = -(
+        conditional_probs * conditional_probs.clamp_min(1e-12).log()
+    ).sum(dim=-1) / math.log(1001.0)
+
+    image_diagonal = torch.linalg.vector_norm(image_size, dim=-1).clamp_min(1e-6)
+    predicted_center = linear_soft_values[:, :2] * image_size / 1000.0
+    target_center = best_target[:, :2] * image_size / 1000.0
+    center_per_block = F.smooth_l1_loss(
+        predicted_center, target_center, reduction="none"
+    ).mean(dim=-1) / image_diagonal
+    predicted_width = linear_soft_values[:, 3] * image_diagonal / 1000.0
+    target_width = best_target[:, 3] * image_diagonal / 1000.0
+    width_per_block = F.smooth_l1_loss(
+        predicted_width, target_width, reduction="none"
+    ) / image_diagonal
+    angle_per_block, angle_resultant = double_angle_loss(
+        conditional_probs[:, 2, :], best_target[:, 2]
+    )
+
+    confidence_gate = (
+        (coord_mass.min(dim=-1).values >= coord_mass_threshold)
+        & (coord_entropy.max(dim=-1).values <= coord_entropy_threshold)
+        & (angle_resultant >= angle_resultant_threshold)
+    ).detach()
+    valid_angle = (
+        confidence_gate
+        & (predicted_width / image_diagonal > minimum_width_diagonal)
+        & (target_width / image_diagonal > minimum_width_diagonal)
+    ).detach()
+    confidence = confidence_gate.float()
+    angle_gate = valid_angle.float()
+    output = GraspRectLossOutput(
+        pose_sum=pose_per_block.sum(),
+        center_sum=(center_per_block * confidence).sum(),
+        angle_sum=(angle_per_block * angle_gate).sum(),
+        width_sum=(width_per_block * confidence).sum(),
+        grasp_count=confidence.new_tensor(float(block_count)),
+        geometry_active_count=confidence.sum().detach(),
+        coord_mass_min=coord_mass.min().detach(),
+        coord_entropy_max=coord_entropy.max().detach(),
+        angle_resultant_min=angle_resultant.min().detach(),
+        cx_top1_correct=exact_slots[:, 0].sum().detach(),
+        cy_top1_correct=exact_slots[:, 1].sum().detach(),
+        theta_exact_top1_correct=exact_slots[:, 2].sum().detach(),
+        theta_circular_within1_correct=theta_within1.sum().detach(),
+        width_top1_correct=exact_slots[:, 3].sum().detach(),
+        pose_four_slot_top1_correct=exact_slots.all(dim=-1).sum().detach(),
+    )
+    for name in ("pose_sum", "center_sum", "angle_sum", "width_sum"):
+        if not torch.isfinite(getattr(output, name)):
+            raise FloatingPointError(f"non-finite grasp rect loss: {name}")
+    return output
