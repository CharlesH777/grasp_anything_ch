+    del logits
+    coord_start = token_ids['coord_start_token_id']
+    coord_end = token_ids['coord_end_token_id']
+    rect_start = token_ids.get(
+        'grasp_rect_start_token_id', token_ids['box_start_token_id']
+    )
+    rect_end = token_ids.get(
+        'grasp_rect_end_token_id', token_ids['box_end_token_id']
