+"""Loss utilities for joint two-contact-point PBD training."""
+
+from __future__ import annotations
+
+import math
+from dataclasses import dataclass
+
+import torch
+import torch.nn.functional as F
+
+
+@dataclass
+class ContactLossOutput:
+    pair_sum: torch.Tensor
+    center_sum: torch.Tensor
+    angle_sum: torch.Tensor
+    width_sum: torch.Tensor
+    contact_count: torch.Tensor
+    geometry_active_count: torch.Tensor
+    coord_mass_min: torch.Tensor
+    coord_entropy_max: torch.Tensor
+
+
+def compute_task_adapter_cross_entropy(
+    lm_head: torch.nn.Module,
+    hidden_states: torch.Tensor,
+    labels: torch.Tensor,
+) -> torch.Tensor:
+    """Compute summed CE through the same hooked LM head used by inference."""
+    if hidden_states.ndim != 2 or labels.ndim != 1:
+        raise ValueError(
+            "task-adapter CE expects [tokens, hidden] and [tokens]: "
+            f"hidden={tuple(hidden_states.shape)}, labels={tuple(labels.shape)}"
+        )
+    if hidden_states.shape[0] != labels.shape[0] or labels.numel() == 0:
+        raise ValueError(
+            "task-adapter CE requires one non-empty label per hidden state: "
+            f"hidden={hidden_states.shape[0]}, labels={labels.numel()}"
+        )
+    logits = lm_head(hidden_states)
+    if not torch.isfinite(logits).all():
+        raise FloatingPointError("non-finite logits after grasp output adapter")
+    return F.cross_entropy(logits.float(), labels, reduction="sum")
+
+
+def combine_base_and_pair_ce(
+    base_loss_sum: torch.Tensor,
+    pair_loss_sum: torch.Tensor,
+    global_ce_token_count: torch.Tensor | float | int,
+    pair_weight: float = 1.0,
+) -> torch.Tensor:
+    """Replace four coordinate-token CEs without changing token-level scale.
+
+    ``pair_loss_sum`` contains one four-slot *mean* per contact block.  Convert
+    it back to a token numerator before combining it with the non-coordinate CE
+    numerator.  The denominator must therefore include all valid labels,
+    including the four coordinate slots owned by pair loss.
+    """
+    denominator = torch.as_tensor(
+        global_ce_token_count,
+        device=base_loss_sum.device,
+        dtype=torch.float32,
+    ).clamp_min(1.0)
+    pair_token_sum = 4.0 * pair_loss_sum
+    return (
+        base_loss_sum + float(pair_weight) * pair_token_sum
+    ) / denominator
+
+
+@torch.no_grad()
+def compute_coordinate_token_metrics(
+    lm_head: torch.nn.Module,
+    hidden_states: torch.Tensor,
+    labels: torch.Tensor,
+) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
+    """Measure coordinate-token CE and top-1 accuracy without adding loss."""
+    if hidden_states.ndim != 2 or labels.ndim != 1:
+        raise ValueError(
+            "coordinate metrics expect [tokens, hidden] and [tokens]: "
+            f"hidden={tuple(hidden_states.shape)}, labels={tuple(labels.shape)}"
+        )
+    if hidden_states.shape[0] != labels.shape[0] or labels.numel() == 0:
+        raise ValueError(
+            "coordinate metrics require one non-empty label per hidden state"
+        )
+    logits = lm_head(hidden_states)
+    if not torch.isfinite(logits).all():
+        raise FloatingPointError(
+            "non-finite logits while computing coordinate-token metrics"
+        )
+    logits = logits.float()
+    ce_sum = F.cross_entropy(logits, labels, reduction="sum")
+    correct = logits.argmax(dim=-1).eq(labels).sum()
+    count = labels.new_tensor(labels.numel())
+    return ce_sum.detach(), correct.detach(), count.detach()
+
+
+def configure_llm_lora(model, requested_rank: int) -> bool:
+    """Install LLM LoRA once and keep adapters trainable after base freezing.
+
+    Returns True when a new adapter is installed and False when an adapter from
+    a checkpoint is reused.
+    """
+    requested_rank = int(requested_rank)
+    if requested_rank <= 0:
+        raise ValueError("LLM LoRA rank must be positive")
+
+    configured_rank = int(
+        getattr(model.config, "use_llm_lora", 0) or 0
+    )
+    already_wrapped = bool(getattr(model, "use_llm_lora", False))
+    if already_wrapped:
+        if configured_rank != requested_rank:
+            raise ValueError(
+                "LoRA checkpoint rank does not match requested rank: "
+                f"checkpoint={configured_rank}, requested={requested_rank}"
+            )
+        adapter_parameters = [
+            parameter
+            for name, parameter in model.language_model.named_parameters()
+            if "lora_" in name
+        ]
+        if not adapter_parameters:
+            raise ValueError("model reports LLM LoRA but has no adapter parameters")
+        for parameter in adapter_parameters:
+            parameter.requires_grad = True
+        model.language_model.enable_input_require_grads()
+        return False
+
+    if configured_rank:
+        raise ValueError(
+            "model config requests LLM LoRA but the model is not wrapped: "
+            f"rank={configured_rank}"
+        )
+    model.wrap_llm_lora(
+        r=requested_rank,
+        lora_alpha=2 * requested_rank,
+        lora_dropout=0.05,
+    )
+    model.config.use_llm_lora = requested_rank
+    return True
+
+
+def enable_task_token_training(model, token_ids: list[int]) -> int:
+    """Enable compact grasp-token input/output adapters."""
+    unique_ids = sorted({int(token_id) for token_id in token_ids})
+    if not unique_ids:
+        raise ValueError("task token IDs must not be empty")
+    configured_ids = sorted(
+        int(token_id)
+        for token_id in getattr(model.config, "grasp_task_token_ids", [])
+    )
+    if configured_ids != unique_ids:
+        raise ValueError(
+            "grasp task token IDs differ from the model configuration: "
+            f"configured={configured_ids}, requested={unique_ids}"
+        )
+    input_adapter = getattr(model, "grasp_task_embedding_delta", None)
+    output_adapter = getattr(model, "grasp_task_output_delta", None)
+    if (
+        input_adapter is None
+        or output_adapter is None
+        or input_adapter.shape[0] != len(unique_ids)
+        or output_adapter.shape != input_adapter.shape
+    ):
+        raise ValueError("model has no compatible grasp task embedding adapter")
+    for embedding in (
+        model.language_model.get_input_embeddings(),
+        model.language_model.get_output_embeddings(),
+    ):
+        if embedding.weight.requires_grad:
+            raise ValueError("base embedding/lm_head must remain frozen")
+    input_adapter.requires_grad = True
+    output_adapter.requires_grad = True
+    return model.register_grasp_task_embedding_hook()
+
+
+def enable_grasp_rect_task_token_training(
+    model, token_ids: list[int]
+) -> int:
+    """Enable the independent rectangular-grasp token adapters."""
+    unique_ids = sorted({int(token_id) for token_id in token_ids})
+    configured_ids = sorted(
+        int(token_id)
+        for token_id in getattr(model.config, "grasp_rect_task_token_ids", [])
+    )
+    if configured_ids != unique_ids or not unique_ids:
+        raise ValueError(
+            "grasp rect task token IDs differ from model configuration: "
+            f"configured={configured_ids}, requested={unique_ids}"
+        )
+    input_adapter = getattr(model, "grasp_rect_task_embedding_delta", None)
+    output_adapter = getattr(model, "grasp_rect_task_output_delta", None)
+    if (
+        input_adapter is None
+        or output_adapter is None
+        or input_adapter.shape[0] != len(unique_ids)
+        or output_adapter.shape != input_adapter.shape
+    ):
+        raise ValueError("model has no compatible grasp rect task adapter")
+    for embedding in (
+        model.language_model.get_input_embeddings(),
+        model.language_model.get_output_embeddings(),
+    ):
+        if embedding.weight.requires_grad:
+            raise ValueError("base embedding/lm_head must remain frozen")
+    input_adapter.requires_grad = True
+    output_adapter.requires_grad = True
+    return model.register_grasp_rect_task_embedding_hook()
+
+
+def freeze_task_token_adapters(model) -> int:
+    """Freeze every structured-task delta before enabling one active task."""
+    frozen_parameters = 0
+    for name in (
+        "grasp_task_embedding_delta",
+        "grasp_task_output_delta",
+        "grasp_rect_task_embedding_delta",
+        "grasp_rect_task_output_delta",
+    ):
+        parameter = getattr(model, name, None)
+        if parameter is None:
+            continue
+        parameter.requires_grad = False
+        frozen_parameters += parameter.numel()
+    return frozen_parameters
+
+
+def register_all_task_token_hooks(model) -> int:
+    """Reattach both task hooks after embedding or LM-head replacement."""
+    registered_parameters = 0
+    for method_name in (
+        "register_grasp_task_embedding_hook",
+        "register_grasp_rect_task_embedding_hook",
+    ):
+        method = getattr(model, method_name, None)
+        if method is not None:
+            registered_parameters += int(method())
+    return registered_parameters
+
+
+def activate_task_token_adapter(
+    model, task: str, token_ids: list[int]
+) -> int:
+    """Freeze both adapters, reattach both hooks, and enable only one task."""
+    freeze_task_token_adapters(model)
+    register_all_task_token_hooks(model)
+    if task == "grasp_contact":
+        return enable_task_token_training(model, token_ids)
+    if task == "grasp_rect":
+        return enable_grasp_rect_task_token_training(model, token_ids)
+    raise ValueError(f"unsupported structured task adapter: {task!r}")
+
+
+def initialize_missing_task_adapters(model, missing_keys: list[str]) -> int:
+    """Zero only task adapters absent from the loaded checkpoint.
+
+    Transformers may run its generic missing-weight initializer after the model
+    constructor, so constructor-level ``torch.zeros`` is not sufficient.  A
+    resumed grasp checkpoint must retain its learned adapter values, however.
+    """
+    missing_names = {
+        key.rsplit(".", 1)[-1]
+        for key in missing_keys
+    }
+    initialized_parameters = 0
+    for name in (
+        "grasp_task_embedding_delta",
+        "grasp_task_output_delta",
+        "grasp_rect_task_embedding_delta",
+        "grasp_rect_task_output_delta",
+    ):
+        parameter = getattr(model, name, None)
+        if parameter is None:
+            continue
+        if name in missing_names:
+            with torch.no_grad():
+                parameter.zero_()
+            initialized_parameters += parameter.numel()
+        if not torch.isfinite(parameter).all():
+            raise FloatingPointError(
+                f"Non-finite values in loaded task adapter: {name}"
+            )
+    return initialized_parameters
+
+
+def validate_coordinate_token_range(start_token_id: int, end_token_id: int) -> None:
+    if end_token_id - start_token_id != 1000:
+        raise ValueError(
+            "contact loss requires exactly 1001 contiguous coordinate tokens; "
+            f"got IDs [{start_token_id}, {end_token_id}]"
+        )
+
+
+def pi_periodic_angle_loss(cosine: torch.Tensor) -> torch.Tensor:
+    """Return a stable, endpoint-exchange-invariant angular loss.
+
+    The forward value is ``1 - |cos(theta)|``.  Expressing the absolute value
+    with an explicit branch gives the ambiguous 90-degree case a deterministic
+    non-zero subgradient.  In contrast, ``1 - cos(theta)^2`` has exactly zero
+    gradient at 90 degrees and cannot recover from that worst-case prediction.
+    """
+    cosine = cosine.clamp(-1.0, 1.0)
+    aligned_cosine = torch.where(cosine >= 0.0, cosine, -cosine)
+    return 1.0 - aligned_cosine
+
+
+def _empty_output(hidden_states: torch.Tensor) -> ContactLossOutput:
+    zero = hidden_states.sum() * 0.0
+    scalar_zero = zero.detach().new_zeros(())
+    return ContactLossOutput(
+        pair_sum=zero,
+        center_sum=zero,
+        angle_sum=zero,
+        width_sum=zero,
+        contact_count=scalar_zero,
+        geometry_active_count=scalar_zero,
+        # Neutral sentinel for a cross-rank MIN reduction when this rank has
+        # no positive contact block.
+        coord_mass_min=scalar_zero.new_ones(()),
+        coord_entropy_max=scalar_zero,
+    )
+
+
+def _filter_colliding_candidates(
+    candidate_mask: torch.Tensor,
+    candidate_collision_2d: torch.Tensor | None,
+    candidate_outside_2d: torch.Tensor | None,
+    collision_valid: torch.Tensor | None,
+    collision_threshold: float,
+    outside_threshold: float,
+) -> torch.Tensor:
+    if candidate_collision_2d is None and candidate_outside_2d is None:
+        return candidate_mask
+
+    safe_candidates = candidate_mask.clone()
+    filterable = torch.zeros(
+        (candidate_mask.shape[0], 1),
+        dtype=torch.bool,
+        device=candidate_mask.device,
+    )
+    if candidate_outside_2d is not None:
+        outside_finite = torch.isfinite(candidate_outside_2d)
+        outside_known = (outside_finite | ~candidate_mask).all(
+            dim=-1, keepdim=True
+        )
+        outside_safe = outside_finite & (
+            candidate_outside_2d <= outside_threshold
+        )
+        safe_candidates &= torch.where(
+            outside_known, outside_safe, candidate_mask
+        )
+        filterable |= outside_known
+
+    if candidate_collision_2d is not None and collision_valid is not None:
+        collision_known = collision_valid.bool().unsqueeze(-1)
+        collision_safe = torch.isfinite(candidate_collision_2d) & (
+            candidate_collision_2d <= collision_threshold
+        )
+        safe_candidates &= torch.where(
+            collision_known, collision_safe, candidate_mask
+        )
+        filterable |= collision_known
+
+    return torch.where(filterable, safe_candidates, candidate_mask)
+
+
+def compute_contact_auxiliary_losses(
+    *,
+    hidden_states: torch.Tensor,
+    lm_head_weight: torch.Tensor,
+    lm_head: torch.nn.Module | None = None,
+    contact_mtp_coord_mask: torch.Tensor,
+    contact_candidates: torch.Tensor,
+    contact_candidate_mask: torch.Tensor,
+    contact_positive_mask: torch.Tensor,
+    contact_image_size: torch.Tensor,
+    coord_start_token_id: int,
+    coord_end_token_id: int,
+    candidate_collision_2d: torch.Tensor | None = None,
+    candidate_outside_2d: torch.Tensor | None = None,
+    collision_valid: torch.Tensor | None = None,
+    collision_threshold: float = 0.0,
+    outside_threshold: float = 0.0,
+    coord_mass_threshold: float = 0.35,
+    coord_entropy_threshold: float = 0.85,
+    minimum_width_diagonal: float = 1e-4,
+) -> ContactLossOutput:
+    """Compute hard-min pair CE and gated image-space geometry losses.
+
+    ``contact_mtp_coord_mask`` is label-aligned. The causal shift is applied here,
+    so each selected hidden state predicts one of the four coordinate labels.
+    """
+
+    validate_coordinate_token_range(coord_start_token_id, coord_end_token_id)
+    if contact_mtp_coord_mask.shape != hidden_states.shape[:2]:
+        raise ValueError(
+            "contact coordinate mask must match hidden sequence shape: "
+            f"mask={tuple(contact_mtp_coord_mask.shape)}, "
+            f"hidden={tuple(hidden_states.shape[:2])}"
+        )
+
+    shift_mask = contact_mtp_coord_mask[..., 1:].bool().reshape(-1)
+    selected_hidden = hidden_states[..., :-1, :].reshape(
+        -1, hidden_states.shape[-1]
+    )[shift_mask]
+    if selected_hidden.numel() == 0:
+        if contact_positive_mask.bool().any():
+            raise ValueError("positive contact sample has no four-coordinate MTP block")
+        return _empty_output(hidden_states)
+    if selected_hidden.shape[0] % 4 != 0:
+        raise ValueError(
+            "contact MTP coordinate mask must select a multiple of four slots; "
+            f"got {selected_hidden.shape[0]}"
+        )
+
+    block_count = selected_hidden.shape[0] // 4
+    positive_indices = contact_positive_mask.bool().nonzero(as_tuple=False).flatten()
+    if positive_indices.numel() != block_count:
+        raise ValueError(
+            "positive sample/contact block count mismatch: "
+            f"positive_samples={positive_indices.numel()}, blocks={block_count}"
+        )
+
+    candidates = contact_candidates[positive_indices].long()
+    candidate_mask = contact_candidate_mask[positive_indices].bool()
+    image_size = contact_image_size[positive_indices].float()
+    if candidates.ndim != 3 or candidates.shape[-1] != 4:
+        raise ValueError(
+            "contact_candidates must have shape [samples, K, 4], "
+            f"got {candidates.shape}"
+        )
+    if not candidate_mask.any(dim=-1).all():
+        raise ValueError("every positive contact sample needs at least one candidate")
+    if (candidates[candidate_mask] < 0).any() or (
+        candidates[candidate_mask] > 1000
+    ).any():
+        raise ValueError("contact candidate values must be in [0, 1000]")
+    if (image_size <= 0).any() or not torch.isfinite(image_size).all():
+        raise ValueError("positive contact samples need finite positive image sizes")
+
+    if candidate_collision_2d is not None:
+        candidate_collision_2d = candidate_collision_2d[positive_indices].float()
+    if candidate_outside_2d is not None:
+        candidate_outside_2d = candidate_outside_2d[positive_indices].float()
+    if collision_valid is not None:
+        collision_valid = collision_valid[positive_indices].bool()
+    effective_mask = _filter_colliding_candidates(
+        candidate_mask,
+        candidate_collision_2d,
+        candidate_outside_2d,
+        collision_valid,
+        collision_threshold,
+        outside_threshold,
+    )
+
+    valid_block_mask = effective_mask.any(dim=-1)
+    if not valid_block_mask.any():
+        return _empty_output(hidden_states)
+    if not valid_block_mask.all():
+        selected_hidden = selected_hidden.reshape(block_count, 4, -1)[
+            valid_block_mask
+        ].reshape(-1, hidden_states.shape[-1])
+        candidates = candidates[valid_block_mask]
+        effective_mask = effective_mask[valid_block_mask]
+        image_size = image_size[valid_block_mask]
+        block_count = int(valid_block_mask.sum().item())
+
+    block_hidden = selected_hidden.reshape(block_count, 4, -1)
+    if lm_head is None:
+        logits = torch.einsum(
+            "bph,vh->bpv",
+            block_hidden.to(dtype=lm_head_weight.dtype),
+            lm_head_weight,
+        )
+    else:
+        # Calling the module, rather than F.linear on its weight, applies the
+        # exact grasp-token output hook used by generation at every slot.
+        logits = lm_head(block_hidden.to(dtype=lm_head_weight.dtype))
+    logits = logits.float()
+    log_probs = F.log_softmax(logits, dim=-1)
+
+    target_ids = candidates + coord_start_token_id
+    expanded_log_probs = log_probs.unsqueeze(1).expand(
+        -1, candidates.shape[1], -1, -1
+    )
+    identity_log_probs = expanded_log_probs.gather(
+        -1, target_ids.unsqueeze(-1)
+    ).squeeze(-1)
+    swapped_ids = target_ids[..., [2, 3, 0, 1]]
+    swapped_log_probs = expanded_log_probs.gather(
+        -1, swapped_ids.unsqueeze(-1)
+    ).squeeze(-1)
+    identity_loss = -identity_log_probs.mean(dim=-1)
+    swapped_loss = -swapped_log_probs.mean(dim=-1)
+    candidate_orientation_loss = torch.stack(
+        (identity_loss, swapped_loss), dim=-1
+    )
+    candidate_orientation_loss = candidate_orientation_loss.masked_fill(
+        ~effective_mask.unsqueeze(-1), torch.inf
+    )
+    pair_per_block, flat_best_index = candidate_orientation_loss.flatten(1).min(
+        dim=-1
+    )
+    if not torch.isfinite(pair_per_block).all():
+        raise FloatingPointError("non-finite contact pair loss")
+    best_candidate_index = torch.div(
+        flat_best_index, 2, rounding_mode="floor"
+    )
+    batch_index = torch.arange(block_count, device=hidden_states.device)
+    best_target = candidates[batch_index, best_candidate_index].float()
+
+    coord_probs = log_probs[
+        ..., coord_start_token_id : coord_end_token_id + 1
+    ].exp()
+    coord_mass = coord_probs.sum(dim=-1)
+    conditional_coord_probs = coord_probs / coord_mass.unsqueeze(-1).clamp_min(1e-12)
+    coordinate_values = torch.arange(
+        1001, device=hidden_states.device, dtype=torch.float32
+    )
+    soft_coordinates = (
+        conditional_coord_probs * coordinate_values.view(1, 1, -1)
+    ).sum(dim=-1)
+    coord_entropy = -(
+        conditional_coord_probs
+        * conditional_coord_probs.clamp_min(1e-12).log()
+    ).sum(dim=-1) / math.log(1001.0)
+
+    widths_heights = image_size[:, [0, 1, 0, 1]]
+    predicted_pixels = soft_coordinates * widths_heights / 1000.0
+    target_pixels = best_target * widths_heights / 1000.0
+    image_diagonal = torch.linalg.vector_norm(image_size, dim=-1).clamp_min(1e-6)
+
+    predicted_center = 0.5 * (
+        predicted_pixels[:, :2] + predicted_pixels[:, 2:]
+    )
+    target_center = 0.5 * (target_pixels[:, :2] + target_pixels[:, 2:])
+    # Apply SmoothL1 in pixel space, then normalize the resulting loss.  Doing
+    # the normalization first puts ordinary errors inside SmoothL1's quadratic
+    # region and shrinks useful geometry gradients by another diagonal factor.
+    center_per_block = F.smooth_l1_loss(
+        predicted_center,
+        target_center,
+        reduction="none",
+    ).mean(dim=-1) / image_diagonal
+
+    predicted_vector = predicted_pixels[:, 2:] - predicted_pixels[:, :2]
+    target_vector = target_pixels[:, 2:] - target_pixels[:, :2]
+    predicted_width = torch.linalg.vector_norm(predicted_vector, dim=-1)
+    target_width = torch.linalg.vector_norm(target_vector, dim=-1)
+    width_per_block = F.smooth_l1_loss(
+        predicted_width,
+        target_width,
+        reduction="none",
+    ) / image_diagonal
+    cosine = (predicted_vector * target_vector).sum(dim=-1) / (
+        predicted_width.clamp_min(1e-6) * target_width.clamp_min(1e-6)
+    )
+    angle_per_block = pi_periodic_angle_loss(cosine)
+
+    confidence_gate = (
+        (coord_mass.min(dim=-1).values >= coord_mass_threshold)
+        & (coord_entropy.max(dim=-1).values <= coord_entropy_threshold)
+    ).detach()
+    valid_angle = (
+        confidence_gate
+        & (predicted_width / image_diagonal >= minimum_width_diagonal)
+        & (target_width / image_diagonal >= minimum_width_diagonal)
+    ).detach()
+    confidence = confidence_gate.float()
+    angle_gate = valid_angle.float()
+    output = ContactLossOutput(
+        pair_sum=pair_per_block.sum(),
+        center_sum=(center_per_block * confidence).sum(),
+        angle_sum=(angle_per_block * angle_gate).sum(),
+        width_sum=(width_per_block * confidence).sum(),
+        contact_count=confidence.new_tensor(float(block_count)),
+        geometry_active_count=confidence.sum().detach(),
+        coord_mass_min=coord_mass.min().detach(),
+        coord_entropy_max=coord_entropy.max().detach(),
+    )
+    for name in ("pair_sum", "center_sum", "angle_sum", "width_sum"):
+        if not torch.isfinite(getattr(output, name)):
+            raise FloatingPointError(f"non-finite contact loss component: {name}")
+    return output
