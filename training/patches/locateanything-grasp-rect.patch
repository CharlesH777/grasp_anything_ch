+        raise ValueError('gripper_depth_pixels must be positive')
+    if not 0.0 <= float(coord_entropy_threshold) <= 1.0:
+        raise ValueError('coord_entropy_threshold must be in [0, 1]')
+    if image_size is not None:
+        size = torch.as_tensor(image_size).flatten()
+        if size.numel() != 2:
+            raise ValueError('image_size must be (width, height) for grasp rect')
+        if float(size[0].item()) <= 0 or float(size[1].item()) <= 0:
+            raise ValueError('image_size values must be positive')
+    if not force_frame and probs[0, rect_start] < start_thresh:
+        return None
+    if force_frame and probs[1, none_token] >= probs[
+        1, coord_start : coord_end + 1
+    ].max():
+        return torch.tensor(
+            [rect_start, none_token, rect_end, null_token, null_token, null_token],
+            dtype=torch.long,
+            device=probs.device,
+        )
