+        default=1,
+        metadata={
+            'help': (
+                'Fixed candidate slots for every task. Keep at 1 through contact '
+                'training phases 1-4 and increase only for multi-GT training.'
+            )
+        },
+    )
+    grasp_rect_max_candidates: int = field(
+        default=1,
+        metadata={
+            'help': (
+                'Fixed rectangular-grasp candidate slots. Keep at 1 until '
+                'the multi-GT grasp-rect phase.'
+            )
+        },
