# MODEL_PATH and META_PATH are required external assets and intentionally unset.
PROJECT_ROOT=${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}
MODEL_PATH=${MODEL_PATH:-}
EAGLE_ROOT=${EAGLE_ROOT:-${PROJECT_ROOT}/training/Eagle}
PYTHON_BIN=${PYTHON_BIN:-${PROJECT_ROOT}/.venv/bin/python}
META_PATH=${META_PATH:-}
PHASE0_AUDIT_PATH=${PHASE0_AUDIT_PATH:-}
REALVLG_OUTPUT_DIR=${REALVLG_OUTPUT_DIR:-${PROJECT_ROOT}/training/outputs/grasp_rect}

GRASP_RECT_PHASE=overfit
NPROC_PER_NODE=4
CUDA_VISIBLE_DEVICES=0,1,2,3
MAX_SEQ_LENGTH=2048
PER_DEVICE_TRAIN_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=4
MAX_STEPS=300
LEARNING_RATE=1e-5
LLM_LORA_RANK=32
VISION_LORA_RANK=0
VISION_LORA_LAST_LAYERS=4

GRASP_RECT_MAX_CANDIDATES=8
GRASP_RECT_POSE_WEIGHT=1.0
GRASP_RECT_CENTER_WEIGHT=0.25
GRASP_RECT_ANGLE_WEIGHT=0.10
GRASP_RECT_WIDTH_WEIGHT=0.10
GRASP_RECT_GEOMETRY_START_BLOCKS=0
GRASP_RECT_GEOMETRY_RAMP_BLOCKS=20000
GRASP_RECT_COORD_MASS_THRESHOLD=0.35
GRASP_RECT_COORD_ENTROPY_THRESHOLD=0.85
GRASP_RECT_ANGLE_RESULTANT_THRESHOLD=0.05
GRASP_RECT_MINIMUM_WIDTH_DIAGONAL=0.0001
GRASP_RECT_COLLISION_THRESHOLD=0.0
GRASP_RECT_OUTSIDE_THRESHOLD=0.0

GRASP_RECT_MIN_SAMPLES=1
GRASP_RECT_MIN_FULL_SAMPLES=1000
GRASP_RECT_MIN_NEGATIVE_SAMPLES=1
GRASP_RECT_MIN_POSITIVE_FRACTION=0.70
GRASP_RECT_MIN_NEGATIVE_FRACTION=0.01
GROUNDING_MIN_REPLAY_SAMPLES=1
GROUNDING_MIN_REPLAY_FRACTION=0.15

DATALOADER_NUM_WORKERS=4
PACKING_BUFFER_SIZE=16
LOGGING_STEPS=5
SAVE_STEPS=250
SAVE_TOTAL_LIMIT=3
SEED=42
