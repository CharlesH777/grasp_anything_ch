PROJECT_ROOT=${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}
EAGLE_ROOT=${EAGLE_ROOT:-${PROJECT_ROOT}/training/Eagle}
PYTHON_BIN=${PYTHON_BIN:-${PROJECT_ROOT}/training/.venv/bin/python}
MODEL_PATH=${MODEL_PATH:-nvidia/LocateAnything-3B}
META_PATH=${META_PATH:-${PROJECT_ROOT}/training/data/voc_train_meta.json}
OUTPUT_ROOT=${OUTPUT_ROOT:-${PROJECT_ROOT}/training/outputs}
LOG_ROOT=${LOG_ROOT:-${PROJECT_ROOT}/training/logs}
HF_HOME=${HF_HOME:-${PROJECT_ROOT}/models/huggingface}

RUN_MODE=${RUN_MODE:-probe}
AUTO_STOP_INFERENCE=${AUTO_STOP_INFERENCE:-0}
MINIMUM_FREE_MEMORY_MIB=${MINIMUM_FREE_MEMORY_MIB:-22000}
GPU_RELEASE_TIMEOUT_SECONDS=${GPU_RELEASE_TIMEOUT_SECONDS:-30}
GPU_RELEASE_POLL_SECONDS=${GPU_RELEASE_POLL_SECONDS:-1}

PROBE_MAX_STEPS=${PROBE_MAX_STEPS:-50}
PROBE_LORA_RANK=${PROBE_LORA_RANK:-16}
PROBE_MAX_SEQ_LENGTH=${PROBE_MAX_SEQ_LENGTH:-1536}
PROBE_GRADIENT_ACCUMULATION=${PROBE_GRADIENT_ACCUMULATION:-8}

TRAIN_MAX_STEPS=${TRAIN_MAX_STEPS:-2500}
TRAIN_LORA_RANK=${TRAIN_LORA_RANK:-32}
TRAIN_MAX_SEQ_LENGTH=${TRAIN_MAX_SEQ_LENGTH:-2048}
TRAIN_GRADIENT_ACCUMULATION=${TRAIN_GRADIENT_ACCUMULATION:-16}

LEARNING_RATE=${LEARNING_RATE:-2e-5}
LR_SCHEDULER_TYPE=${LR_SCHEDULER_TYPE:-cosine}
WEIGHT_DECAY=${WEIGHT_DECAY:-0.01}
WARMUP_RATIO=${WARMUP_RATIO:-0.03}
PACKING_BUFFER_SIZE=${PACKING_BUFFER_SIZE:-4}
DATALOADER_NUM_WORKERS=${DATALOADER_NUM_WORKERS:-0}
PER_DEVICE_TRAIN_BATCH_SIZE=${PER_DEVICE_TRAIN_BATCH_SIZE:-1}
SAVE_STEPS=${SAVE_STEPS:-250}
SAVE_TOTAL_LIMIT=${SAVE_TOTAL_LIMIT:-2}
LOGGING_STEPS=${LOGGING_STEPS:-5}
SAMPLE_LOG_INTERVAL=${SAMPLE_LOG_INTERVAL:-50}
SEED=${SEED:-42}
