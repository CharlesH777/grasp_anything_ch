# Generic 4-GPU profile. Supply MODEL_PATH and META_PATH in the environment.
PROJECT_ROOT=${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}
MODEL_PATH=${MODEL_PATH:-}
EAGLE_ROOT=${EAGLE_ROOT:-${PROJECT_ROOT}/training/Eagle}
PYTHON_BIN=${PYTHON_BIN:-${PROJECT_ROOT}/.venv/bin/python}
CUDA_HOME=${CUDA_HOME:-}
TORCH_EXTENSIONS_DIR=${TORCH_EXTENSIONS_DIR:-${PROJECT_ROOT}/training/.cache/torch_extensions}
TRITON_CACHE_DIR=${TRITON_CACHE_DIR:-${PROJECT_ROOT}/training/.cache/triton}
MAX_JOBS=4
META_PATH=${META_PATH:-}
REALVLG_OUTPUT_DIR=${REALVLG_OUTPUT_DIR:-${PROJECT_ROOT}/training/outputs/contact}

NPROC_PER_NODE=4
CUDA_VISIBLE_DEVICES=0,1,2,3
CONTACT_PHASE=overfit
MAX_SEQ_LENGTH=2048
GRADIENT_ACCUMULATION_STEPS=4
MAX_STEPS=300
LEARNING_RATE=5e-6
LLM_LORA_RANK=32
VISION_LORA_RANK=0
VISION_LORA_LAST_LAYERS=4
WARMUP_RATIO=0.03
WEIGHT_DECAY=0.01
MAX_GRAD_NORM=1.0
LOGGING_STEPS=10
SAVE_STEPS=100
SAVE_TOTAL_LIMIT=2

CONTACT_MAX_CANDIDATES=8
CONTACT_PAIR_MAX_CANDIDATES=1
CONTACT_PAIR_WEIGHT=1.0
CONTACT_CENTER_WEIGHT=0.10
CONTACT_ANGLE_WEIGHT=0.05
CONTACT_WIDTH_WEIGHT=0.05
CONTACT_GEOMETRY_START_BLOCKS=0
CONTACT_GEOMETRY_RAMP_BLOCKS=2000
CONTACT_COORD_MASS_THRESHOLD=0.35
CONTACT_COORD_ENTROPY_THRESHOLD=0.85
CONTACT_COLLISION_THRESHOLD=0.0
CONTACT_OUTSIDE_THRESHOLD=0.0
CONTACT_MIN_CONTACT_SAMPLES=1
CONTACT_MIN_FULL_SAMPLES=1000
GROUNDING_MIN_REPLAY_SAMPLES=1
CONTACT_MIN_NEGATIVE_SAMPLES=1
CONTACT_MIN_POSITIVE_FRACTION=0.70
GROUNDING_MIN_REPLAY_FRACTION=0.15
CONTACT_MIN_NEGATIVE_FRACTION=0.01
